generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model LoginEvent {
  id String @id @default(uuid())

  userId   String  @map("user_id")
  roleType String? @map("role_type")

  message String?
  level   String?

  domainName String? @map("domain_name")
  ipAddress  String? @map("ip_address")

  latitude  Float?
  longitude Float?
  location  String?
  accuracy  Int?

  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("login_events")
}

model AuditLog {
  id         String  @id @default(uuid())
  userId     String? @map("user_id")
  action     String
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")
  ipAddress  String? @map("ip_address")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("audit_logs")
}

model Package {
  id                 String              @id @default(uuid())
  name               String              @unique
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  users              User[]
  commissionSettings CommissionSetting[]
  userLimits         UserLimit[]
  permissions        Permission[]

  @@map("packages")
}

model User {
  id                        String              @id @default(uuid())
  registrationNumber        String              @unique @map("registration_number")
  fullName                  String              @map("full_name")
  companyName               String              @map("company_name")
  companyType               String              @map("company_type") // Proprietorship, Partnership, Pvt Ltd, LLP, etc.
  profileImage              String?             @map("profile_image") @db.Text
  email                     String              @unique
  phoneNumber               String              @unique @map("phone_number")
  password                  String
  transactionPin            String?             @map("transaction_pin") @db.Text
  parentId                  String?             @map("parent_id")
  status                    UserStatus          @default(ACTIVE)
  isKycVerified             Boolean             @default(false) @map("is_kyc_verified")
  role                      String
  packageId                 String?             @map("package_id")
  refreshToken              String?             @map("refresh_token") @db.Text
  passwordForgotToken       String?             @map("password_forgot_token")
  passwordForgotExpires     DateTime?           @map("password_forgot_expires")
  lastPasswordForgot        DateTime?           @map("last_password_forgot")
  lastPasswordChange        DateTime?           @map("last_password_change")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @default(now()) @updatedAt @map("updated_at")
  deletedAt                 DateTime?           @map("deleted_at")
  lastLoginAt               DateTime?           @map("last_login_at")
  deactivationReason        String?             @map("user_deactivation_reason") @db.LongText
  bankAccounts              BankDetail[]
  commissionEarningsCreated CommissionEarning[] @relation("CommissionEarningCreatedBy")
  commissionsGiven          CommissionEarning[] @relation("CommissionEarningFromUser")
  commissionEarnings        CommissionEarning[] @relation("CommissionEarningToUser")
  commissionSetting         CommissionSetting[]
  systemSettings            SystemSetting[]
  transactions              Transaction[]
  userKyc                   UserKyc[]
  parent                    User?               @relation("UserHierarchy", fields: [parentId], references: [id])
  children                  User[]              @relation("UserHierarchy")
  package                   Package?            @relation(fields: [packageId], references: [id])
  wallets                   Wallet[]
  limits                    UserLimit?
  loginEvents               LoginEvent[]
  ledgerEntries             LedgerEntry[]
  apiKeys                   ApiKey[]
  businessKyc               BusinessKyc?
  permissions               Permission[]

  @@index([parentId])
  @@index([phoneNumber])
  @@index([email])
  @@index([registrationNumber])
  @@index([role])
  @@map("users")
}

// API KEY
model ApiKey {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  name              String?
  apiKey            String    @unique @map("api_key")
  secretKey         String    @map("secret_key")
  provider          String?
  allowedIps        Json?     @map("allowed_ips")
  maxIpLimit        Int       @default(5) @map("max_ip_limit")
  callbackUrl       String?   @map("callback_url")
  callbackSecret    String?   @map("callback_secret")
  requestsPerMinute Int       @default(60) @map("requests_per_minute")
  requestsPerDay    Int       @default(10000) @map("requests_per_day")
  isActive          Boolean   @default(true) @map("is_active")
  expiresAt         DateTime? @map("expires_at")
  lastUsedAt        DateTime? @map("last_used_at")
  lastUsedIp        String?   @map("last_used_ip")
  remarks           String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([apiKey])
  @@index([isActive])
  @@index([expiresAt])
  @@map("api_keys")
}

model UserKyc {
  id                 String    @id @default(uuid())
  registrationNumber String    @unique @map("registration_number")
  userId             String    @map("user_id")
  fullName           String    @map("full_name")
  dob                DateTime
  gender             Gender
  status             KycStatus @default(PENDING)
  type               KycTypes  @default(USER_KYC)
  kycType            String    @default("MANUAL")
  kycRejectionReason String?   @map("kyc_rejection_reason") @db.LongText
  addressId          String    @map("address_id")
  panFile            String    @map("pan_file")
  aadhaarFile        String    @map("aadhaar_file")
  addressProofFile   String    @map("address_proof_file")
  photo              String
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  address            Address   @relation(fields: [addressId], references: [id])
  user               User      @relation(fields: [userId], references: [id])

  @@index([addressId], map: "user_kyc_address_id_fkey")
  @@index([userId], map: "user_kyc_user_id_fkey")
  @@map("user_kyc")
}

model BusinessKyc {
  id                 String    @id @default(uuid())
  registrationNumber String    @unique @map("registration_number")
  userId             String    @unique @map("user_id")
  companyName        String    @map("company_name")
  type               String    @map("type") // Proprietorship, Partnership, Pvt Ltd, LLP, etc.
  kycRejectionReason String?   @map("kyc_rejection_reason") @db.LongText
  documentFile       String    @map("document_file")
  addressId          String    @map("address_id")
  status             KycStatus @default(PENDING)
  rejectionReason    String?   @map("rejection_reason")
  verifiedAt         DateTime? @map("verified_at")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id])
  address            Address   @relation(fields: [addressId], references: [id])

  @@map("business_verifications")
}

model BankDetail {
  id                  String      @id @default(uuid())
  accountHolder       String      @map("account_holder") @db.Text
  accountNumber       String      @unique @map("account_number") @db.VarChar(18)
  phoneNumber         String      @map("phone_number")
  accountType         AccountType @map("account_type")
  ifscCode            String      @map("ifsc_code") @db.Text
  bankName            String      @map("bank_name") @db.Text
  bankRejectionReason String?     @map("bank_rejection_reason") @db.LongText
  bankProofFile       String      @map("bank_proof_file")
  status              KycStatus   @default(PENDING)
  isPrimary           Boolean     @default(false) @map("is_primary")
  userId              String      @map("user_id")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime?   @map("deleted_at")
  user                User        @relation(fields: [userId], references: [id])

  @@index([userId], map: "bank_details_user_id_fkey")
  @@map("bank_details")
}

model Beneficiary {
  id            String  @id @default(cuid())
  userId        String  @map("user_id")
  accountNumber String  @map("account_number")
  ifsc          String
  name          String
  mobile        String  @db.VarChar(15)
  isVerified    Boolean @default(false) @map("is_verified")
  metaData      Json?   @map("meta_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, accountNumber, ifsc])
  @@index([userId])
  @@map("beneficiarys")
}

model Address {
  id        String   @id @default(uuid())
  kycId     String   @map("kyc_id")
  type      String   @default("HOME")
  address   String   @db.LongText
  pinCode   String   @map("pin_code")
  state     String   @map("state")
  city      String   @map("city")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userKyc      UserKyc[]
  businessKycs BusinessKyc[]

  @@map("addresses")
}

model Wallet {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  walletType WalletType @map("wallet_type")

  balance     Float
  holdBalance Float @map("hold_balance")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_at")

  user          User          @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]
  transactions  Transaction[]

  @@unique([userId, walletType])
  @@index([userId])
  @@map("wallets")
}

model UserLimit {
  id        String  @id @default(uuid())
  userId    String? @map("user_id")
  packageId String? @map("package_id")

  dailyLimit   Float? @map("daily_limit")
  monthlyLimit Float? @map("monthly_limit")
  perTxnLimit  Float? @map("per_txn_limit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_at")

  user    User?    @relation(fields: [userId], references: [id])
  package Package? @relation(fields: [packageId], references: [id])

  @@unique([userId])
  @@index([dailyLimit, monthlyLimit, perTxnLimit])
  @@map("user_limits")
}

model CommissionSetting {
  id String @id @default(uuid())

  // TARGET
  scope             CommissionScope @default(ROLE)
  targetUserId      String?         @map("target_user_id")
  packageId         String?         @map("package_id")
  serviceProviderId String?         @map("service_provider_id")
  createdBy         String          @map("created_by")

  // BASIC
  isActive             Boolean @default(true) @map("is_active")
  supportsSlab         Boolean @default(false) @map("supports_slab")
  supportPaymentMethod Boolean @default(false) @map("support_payment_method")

  // PAYMENT GATEWAY
  paymentMethod String? @map("payment_method")
  network       String?

  // BBPS / RECHARGE
  category     String?
  operator     String?
  operatorCode String? @map("operator_code")

  // DMT / PAYOUT
  bankCode String? @map("bank_code")

  transactionType String? @map("transaction_type")

  // SLAB
  minAmount Float? @map("min_amount")
  maxAmount Float? @map("max_amount")

  // COMMISSION
  mode  PricingMode    @default(NONE)
  type  CommissionType @default(NONE)
  value Float

  // TAX
  applyTDS   Boolean @default(false) @map("apply_tds")
  tdsPercent Float?  @map("tds_percent")
  applyGST   Boolean @default(false) @map("apply_gst")
  gstPercent Float?  @map("gst_percent")

  // EXTRA
  config Json?

  // TIMESTAMPS
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // RELATIONS
  targetUser      User?            @relation(fields: [targetUserId], references: [id])
  package         Package?         @relation(fields: [packageId], references: [id])
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  // INDEXES
  @@index([targetUserId])
  @@index([serviceProviderId])
  @@index([paymentMethod, network])
  @@index([operatorCode])
  @@index([bankCode])
  @@index([transactionType])
  @@index([minAmount, maxAmount])
  @@map("commission_settings")
}

model CommissionEarning {
  id            String  @id @default(uuid())
  transactionId String  @map("transaction_id")
  userId        String  @map("user_id")
  fromUserId    String? @map("from_user_id")

  serviceProviderMappingId String @map("service_provider_mapping_id")

  amount Float

  mode PricingMode
  type CommissionType

  netAmount Float @map("net_amount")

  metadata Json? @map("meta_data")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])

  user User @relation("CommissionEarningToUser", fields: [userId], references: [id])

  fromUser User? @relation("CommissionEarningFromUser", fields: [fromUserId], references: [id])

  createdByUser     User             @relation("CommissionEarningCreatedBy", fields: [createdBy], references: [id])
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?

  @@index([transactionId, userId])
  @@index([userId, createdAt])
  @@index([serviceProviderMappingId])
  @@map("commission_earnings")
}

model Service {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  serviceProviders ServiceProvider[]
  permissions      Permission[]

  @@map("services")
}

model Provider {
  id   String @id @default(uuid())
  name String
  code String @unique

  // BBPS / PG / DMT / PAYOUT / AEPS
  type String?

  isActive Boolean @default(true) @map("is_active")

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  serviceProviders ServiceProvider[]

  @@map("providers")
}

model ServiceProvider {
  id String @id @default(uuid())

  serviceId  String @map("service_id")
  providerId String @map("provider_id")

  // BASIC
  baseUrl  String? @map("base_url")
  isActive Boolean @default(true) @map("is_active")

  // FEATURES
  supportsSlab         Boolean @default(false) @map("supports_slab")
  supportPaymentMethod Boolean @default(false) @map("support_payment_method")

  // PAYMENT GATEWAY
  paymentMethod String? @map("payment_method")
  network       String?

  // BBPS / RECHARGE
  category     String?
  operator     String?
  operatorCode String? @map("operator_code")

  // DMT / PAYOUT
  bankCode        String? @map("bank_code")
  transactionType String? @map("transaction_type")

  // SLAB
  minAmount Float? @map("min_amount")
  maxAmount Float? @map("max_amount")

  // PRICING
  mode             PricingMode      @default(NONE)
  pricingValueType PricingValueType @default(NONE) @map("pricing_value_type")
  value            Float?
  providerCost     Float?           @map("provider_cost")

  // TAX

  applyTDS   Boolean @default(false) @map("apply_tds")
  tdsPercent Float?  @map("tds_percent")
  applyGST   Boolean @default(false) @map("apply_gst")
  gstPercent Float?  @map("gst_percent")

  // EXTRA
  handlePath String? @map("handle_path")
  config     Json?

  // TIMESTAMPS
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // RELATIONS
  service            Service             @relation(fields: [serviceId], references: [id])
  provider           Provider            @relation(fields: [providerId], references: [id])
  transactions       Transaction[]
  ledgerEntries      LedgerEntry[]
  commissionSettings CommissionSetting[]
  commissionEarnings CommissionEarning[]

  // INDEXES
  @@index([serviceId])
  @@index([providerId])
  @@index([operatorCode])
  @@index([paymentMethod, network])
  @@index([bankCode])
  @@index([transactionType])
  @@index([minAmount, maxAmount])
  @@map("service_providers")
}

model Permission {
  id         String          @id @default(uuid())
  scope      PermissionScope
  userId     String?         @map("user_id")
  packageId  String?         @map("package_id")
  serviceId  String          @map("service_id")
  canView    Boolean         @default(false) @map("can_view")
  canProcess Boolean         @default(false) @map("can_process")
  isActive   Boolean         @default(true) @map("is_active")
  remarks    String?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @updatedAt @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id])
  package Package? @relation(fields: [packageId], references: [id])
  service Service  @relation(fields: [serviceId], references: [id])

  @@unique([userId, serviceId])
  @@unique([packageId, serviceId])
  @@index([userId])
  @@index([packageId])
  @@index([serviceId])
  @@index([scope])
  @@map("permissions")
}

model SystemSetting {
  id            String    @id @default(uuid())
  userId        String?   @map("user_id")
  companyName   String    @map("company_name")
  companyLogo   String    @map("company_logo")
  favIcon       String    @map("fav_icon")
  phoneNumber   String    @map("phone_number")
  whtsappNumber String    @map("whtsapp_number")
  companyEmail  String    @map("company_email")
  facebookUrl   String    @map("facebook_url")
  instagramUrl  String    @map("instagram_url")
  twitterUrl    String    @map("twitter_url")
  linkedinUrl   String    @map("linkedin_url")
  websiteUrl    String    @map("website_url")
  settings      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  user          User?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "settings_user_id_fkey")
  @@map("settings")
}

model Transaction {
  id             String @id @default(uuid())
  idempotencyKey String @unique @map("idempotency_key")
  txnId          String @unique @map("txn_id")

  amount    Float
  netAmount Float @map("net_amount")

  status                   String  @default("PENDING")
  serviceProviderMappingId String? @map("service_provider_mapping_id")
  pricing                  Json?

  userId   String @map("user_id")
  walletId String @map("wallet_id")

  providerReference    String? @map("provider_reference")
  requestInit          Json?   @map("request_init")
  providerResponseInit Json?   @map("provider_response_init")
  providerResponse     Json?   @map("provider_response")
  retryCount           Int     @default(0) @map("retry_count")

  initiatedAt   DateTime  @default(now()) @map("initiated_at")
  processedAt   DateTime? @map("processed_at")
  completedAt   DateTime? @map("completed_at")
  lastCheckedAt DateTime? @map("last_checked_at")

  commissionEarnings CommissionEarning[]
  ledgerEntries      LedgerEntry[]

  user   User   @relation(fields: [userId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])

  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?

  @@index([userId, status])
  @@index([status, initiatedAt])
  @@map("transactions")
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String?         @map("transaction_id")
  walletId      String          @map("wallet_id")
  entryType     LedgerEntryType @map("entry_type")
  referenceType String          @map("reference_type")

  amount         Float
  runningBalance Float        @map("running_balance")
  narration      String       @db.Text
  metadata       Json?
  idempotencyKey String?      @map("idempotency_key")
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  transaction    Transaction? @relation(fields: [transactionId], references: [id])
  wallet         Wallet       @relation(fields: [walletId], references: [id])

  serviceProviderMappingId String?
  createdByUser            User             @relation(fields: [createdBy], references: [id])
  serviceProvider          ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId        String?

  @@unique([idempotencyKey])
  @@index([transactionId])
  @@index([walletId, createdAt])
  @@index([idempotencyKey])
  @@map("ledger_entries")
}

model BbpsCategory {
  id       String @id @default(uuid())
  biller   String
  category String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([biller])
  @@map("bbps_categories")
}

model BbpsBiller {
  id             String @id @default(uuid())
  billerId       String @unique @map("biller_id")
  billerName     String @map("biller_name")
  category       String
  customerParams Json   @map("customer_params")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("bbps_billers")
}

model BbpsFetchBill {
  id     String @id @default(uuid())
  userId String @map("user_id")

  serviceProviderMappingId String @map("service_provider_mapping_id")

  billerId          String  @map("biller_id")
  reference         String
  fetchId           String  @unique @map("fetch_id")
  customerParams    Json?   @map("customer_params")
  customerParamsKey String? @map("customer_params_key")

  amount Float
  status String

  customerName String?   @map("customer_name")
  dueDate      DateTime? @map("due_date")

  rawResponse Json? @map("raw_response")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, billerId, customerParamsKey])
  @@map("bbps_fetch_bill")
}

enum CommissionStartLevel {
  ADMIN_ONLY
  NONE
}

enum RoleType {
  ADMIN
  API_HOLDER
}

enum PricingValueType {
  NONE
  FLAT
  PERCENTAGE
}

enum UserStatus {
  ACTIVE
  IN_ACTIVE
  DELETE
}

enum PermissionScope {
  USER
  PACKAGE
}

enum PricingMode {
  NONE
  COMMISSION
  SURCHARGE
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum CommissionType {
  NONE
  FLAT
  PERCENTAGE
}

enum CommissionScope {
  ROLE
  USER
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECT
}

enum KycTypes {
  AEPS
  USER_KYC
}

enum Currency {
  INR
  USD
  EUR
  GBP
  AED
}

enum WalletType {
  PRIMARY
  COMMISSION
  ESCROW
  BONUS
  GST
  TDS
}

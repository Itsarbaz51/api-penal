generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model LoginEvent {
  id String @id @default(uuid())

  userId   String  @map("user_id")
  roleType String? @map("role_type")
  message  String?

  domainName String? @map("domain_name")
  ipAddress  String? @map("ip_address")

  latitude  Float?
  longitude Float?
  location  String?
  accuracy  Int?

  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("login_events")
}

model AuditLog {
  id       String  @id @default(uuid())
  userId   String? @map("user_id")
  roleType String? @map("role_type")

  // ACTION
  action String
  // CREATE_USER
  // UPDATE_KYC
  // DELETE_API_KEY

  module String?
  // USER
  // KYC
  // WALLET
  // TRANSACTION

  // LOCATION
  latitude  Float?
  longitude Float?
  location  String?

  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")
  requestId  String? @map("request_id")
  method     String? // POST / PATCH / DELETE
  endpoint   String?
  ipAddress  String? @map("ip_address")
  domainName String? @map("domain_name")
  userAgent  String? @map("user_agent")
  status     String? // SUCCESS / FAILED
  message    String?

  oldValues Json? @map("old_values")
  newValues Json? @map("new_values")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Package {
  id                 String              @id @default(uuid())
  name               String              @unique
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  users              User[]
  commissionSettings CommissionSetting[]
  userLimits         UserLimit[]
  permissions        Permission[]

  @@map("packages")
}

model User {
  id                        String              @id @default(uuid())
  registrationNumber        String              @unique @map("registration_number")
  fullName                  String              @map("full_name")
  companyName               String              @map("company_name")
  companyType               String              @map("company_type") // Proprietorship, Partnership, Pvt Ltd, LLP, etc.
  profileImage              String?             @map("profile_image") @db.Text
  email                     String              @unique
  phoneNumber               String              @unique @map("phone_number")
  password                  String
  transactionPin            String?             @map("transaction_pin") @db.Text
  parentId                  String?             @map("parent_id")
  status                    UserStatus          @default(ACTIVE)
  isKycVerified             Boolean             @default(false) @map("is_kyc_verified")
  role                      String
  packageId                 String?             @map("package_id")
  refreshToken              String?             @map("refresh_token") @db.Text
  passwordForgotToken       String?             @map("password_forgot_token")
  passwordForgotExpires     DateTime?           @map("password_forgot_expires")
  lastPasswordForgot        DateTime?           @map("last_password_forgot")
  lastPasswordChange        DateTime?           @map("last_password_change")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @default(now()) @updatedAt @map("updated_at")
  deletedAt                 DateTime?           @map("deleted_at")
  lastLoginAt               DateTime?           @map("last_login_at")
  deactivationReason        String?             @map("user_deactivation_reason") @db.LongText
  bankAccounts              BankDetail[]
  commissionEarningsCreated CommissionEarning[] @relation("CommissionEarningCreatedBy")
  commissionsGiven          CommissionEarning[] @relation("CommissionEarningFromUser")
  commissionEarnings        CommissionEarning[] @relation("CommissionEarningToUser")
  commissionSetting         CommissionSetting[]
  systemSettings            SystemSetting[]
  transactions              Transaction[]

  parent         User?           @relation("UserHierarchy", fields: [parentId], references: [id])
  children       User[]          @relation("UserHierarchy")
  package        Package?        @relation(fields: [packageId], references: [id])
  wallets        Wallet[]
  limits         UserLimit?
  loginEvents    LoginEvent[]
  ledgerEntries  LedgerEntry[]
  apiKeys        ApiKey[]
  permissions    Permission[]
  kyc            Kyc?
  auditLogs      AuditLog[]
  bbpsFetchBills BbpsFetchBill[]

  @@index([parentId])
  @@index([phoneNumber])
  @@index([email])
  @@index([registrationNumber])
  @@index([role])
  @@map("users")
}

// API KEY
model ApiKey {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  name              String?
  apiKey            String    @unique @map("api_key")
  secretKey         String    @map("secret_key")
  provider          String?
  allowedIps        Json?     @map("allowed_ips")
  maxIpLimit        Int       @default(5) @map("max_ip_limit")
  callbackUrl       String?   @map("callback_url")
  callbackSecret    String?   @map("callback_secret")
  requestsPerMinute Int       @default(60) @map("requests_per_minute")
  requestsPerDay    Int       @default(10000) @map("requests_per_day")
  isActive          Boolean   @default(true) @map("is_active")
  expiresAt         DateTime? @map("expires_at")
  lastUsedAt        DateTime? @map("last_used_at")
  lastUsedIp        String?   @map("last_used_ip")
  remarks           String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user                   User                    @relation(fields: [userId], references: [id])
  apiKeyProviderMappings ApiKeyProviderMapping[]

  @@index([userId])
  @@index([apiKey])
  @@index([isActive])
  @@index([expiresAt])
  @@map("api_keys")
}

model ApiReference {
  id String @id @default(uuid())

  name     String
  module   String
  method   String
  endpoint String @unique

  description String? @db.LongText

  // Authentication
  authType String? @default("API_KEY")
  headers  Json? // x-api-key, x-secret-key, Authorization etc.

  // Request
  queryParams   Json? @map("query_params")
  pathParams    Json? @map("path_params")
  requestFields Json? @map("request_fields")
  sampleRequest Json? @map("sample_request")

  // Response
  sampleResponse Json? @map("sample_response")
  responseFields Json? @map("response_fields")

  // Errors
  errorResponses Json? @map("error_responses")

  // Extra
  tags        Json?
  version     String? @default("v1")
  baseUrl     String?
  contentType String? @default("application/json")

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([module])
  @@map("api_references")
}

model Kyc {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique @map("registration_number")
  userId             String        @unique @map("user_id")
  fullName           String        @map("full_name")
  dob                DateTime?
  gender             Gender?
  email              String?
  phoneNumber        String?       @map("phone_number")
  companyName        String?       @map("company_name")
  businessType       String?       @map("business_type")
  status             KycStatus     @default(PENDING)
  kycType            String        @default("MANUAL") @map("kyc_type")
  rejectionReason    String?       @map("rejection_reason") @db.LongText
  verifiedAt         DateTime?     @map("verified_at")
  verifiedBy         String?       @map("verified_by")
  remarks            String?
  metadata           Json?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at")
  user               User          @relation(fields: [userId], references: [id])
  addresses          Address[]
  documents          KycDocument[]

  @@index([status])
  @@index([companyName])
  @@map("kycs")
}

model ApiLanguage {
  id String @id @default(uuid())

  name String @unique
  slug String @unique

  template String @db.LongText

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_languages")
}

model KycDocument {
  id             String    @id @default(uuid())
  kycId          String    @map("kyc_id")
  type           String
  fileUrl        String    @map("file_url")
  documentNumber String?   @map("document_number")
  remarks        String?
  isVerified     Boolean   @default(false) @map("is_verified")
  verifiedAt     DateTime? @map("verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  kyc Kyc @relation(fields: [kycId], references: [id])

  @@index([kycId])
  @@index([type])
  @@index([isVerified])
  @@map("kyc_documents")
}

model BankDetail {
  id                  String      @id @default(uuid())
  accountHolder       String      @map("account_holder") @db.Text
  accountNumber       String      @unique @map("account_number") @db.VarChar(18)
  phoneNumber         String      @map("phone_number")
  accountType         AccountType @map("account_type")
  ifscCode            String      @map("ifsc_code") @db.Text
  bankName            String      @map("bank_name") @db.Text
  bankRejectionReason String?     @map("bank_rejection_reason") @db.LongText
  bankProofFile       String      @map("bank_proof_file")
  status              KycStatus   @default(PENDING)
  isPrimary           Boolean     @default(false) @map("is_primary")
  userId              String      @map("user_id")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime?   @map("deleted_at")
  user                User        @relation(fields: [userId], references: [id])

  @@index([userId], map: "bank_details_user_id_fkey")
  @@map("bank_details")
}

model Beneficiary {
  id            String  @id @default(cuid())
  userId        String  @map("user_id")
  accountNumber String  @map("account_number")
  ifsc          String
  name          String
  mobile        String  @db.VarChar(15)
  isVerified    Boolean @default(false) @map("is_verified")
  metaData      Json?   @map("meta_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, accountNumber, ifsc])
  @@index([userId])
  @@map("beneficiarys")
}

enum AddressType {
  HOME
  OFFICE
}

model Address {
  id        String      @id @default(uuid())
  kycId     String      @map("kyc_id")
  type      AddressType @default(HOME)
  address   String      @db.LongText
  pinCode   String      @map("pin_code")
  state     String
  city      String
  landmark  String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  kyc Kyc @relation(fields: [kycId], references: [id])

  @@index([kycId])
  @@index([type])
  @@map("addresses")
}

model Wallet {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  walletType WalletType @map("wallet_type")

  balance     Float
  holdBalance Float @map("hold_balance")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_at")

  user          User          @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]
  transactions  Transaction[]

  @@unique([userId, walletType])
  @@index([userId])
  @@map("wallets")
}

model UserLimit {
  id        String  @id @default(uuid())
  userId    String? @map("user_id")
  packageId String? @map("package_id")

  dailyLimit   Float? @map("daily_limit")
  monthlyLimit Float? @map("monthly_limit")
  perTxnLimit  Float? @map("per_txn_limit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_at")

  user    User?    @relation(fields: [userId], references: [id])
  package Package? @relation(fields: [packageId], references: [id])

  @@unique([userId])
  @@index([dailyLimit, monthlyLimit, perTxnLimit])
  @@map("user_limits")
}

model CommissionSetting {
  id String @id @default(uuid())

  // TARGET
  scope             CommissionScope @default(ROLE)
  targetUserId      String?         @map("target_user_id")
  packageId         String?         @map("package_id")
  serviceProviderId String?         @map("service_provider_id")
  createdBy         String          @map("created_by")

  // BASIC
  isActive             Boolean @default(true) @map("is_active")
  supportsSlab         Boolean @default(false) @map("supports_slab")
  supportPaymentMethod Boolean @default(false) @map("support_payment_method")

  // PAYMENT GATEWAY
  paymentMethod String? @map("payment_method")
  network       String?

  // BBPS / RECHARGE
  category     String?
  operator     String?
  operatorCode String? @map("operator_code")

  // DMT / PAYOUT
  bankCode String? @map("bank_code")

  transactionType String? @map("transaction_type")

  // SLAB
  minAmount Float? @map("min_amount")
  maxAmount Float? @map("max_amount")

  // COMMISSION
  mode  PricingMode    @default(NONE)
  type  CommissionType @default(NONE)
  value Float

  // TAX
  applyTDS   Boolean @default(false) @map("apply_tds")
  tdsPercent Float?  @map("tds_percent")
  applyGST   Boolean @default(false) @map("apply_gst")
  gstPercent Float?  @map("gst_percent")

  // TIMESTAMPS
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // RELATIONS
  targetUser      User?            @relation(fields: [targetUserId], references: [id])
  package         Package?         @relation(fields: [packageId], references: [id])
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  // INDEXES
  @@index([targetUserId])
  @@index([serviceProviderId])
  @@index([paymentMethod, network])
  @@index([operatorCode])
  @@index([bankCode])
  @@index([transactionType])
  @@index([minAmount, maxAmount])
  @@map("commission_settings")
}

model CommissionEarning {
  id            String  @id @default(uuid())
  transactionId String  @map("transaction_id")
  userId        String  @map("user_id")
  fromUserId    String? @map("from_user_id")

  serviceProviderId String @map("service_provider_id")

  amount Float

  mode PricingMode
  type CommissionType

  netAmount Float @map("net_amount")

  metadata Json? @map("meta_data")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])

  user User @relation("CommissionEarningToUser", fields: [userId], references: [id])

  fromUser User? @relation("CommissionEarningFromUser", fields: [fromUserId], references: [id])

  createdByUser   User             @relation("CommissionEarningCreatedBy", fields: [createdBy], references: [id])
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  @@index([transactionId, userId])
  @@index([userId, createdAt])
  @@index([serviceProviderId])
  @@map("commission_earnings")
}

model Service {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  serviceProviders       ServiceProvider[]
  permissions            Permission[]
  apiKeyProviderMappings ApiKeyProviderMapping[]

  @@map("services")
}

model Provider {
  id   String @id @default(uuid())
  name String
  code String @unique

  // BBPS / PG / DMT / PAYOUT / AEPS
  type String?

  isActive Boolean @default(true) @map("is_active")

  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @default(now()) @updatedAt @map("updated_at")
  serviceProviders       ServiceProvider[]
  bbpsBillers            BbpsBiller[]
  apiKeyProviderMappings ApiKeyProviderMapping[]

  @@map("providers")
}

model ServiceProvider {
  id String @id @default(uuid())

  serviceId  String @map("service_id")
  providerId String @map("provider_id")

  // BASIC
  baseUrl  String? @map("base_url")
  isActive Boolean @default(true) @map("is_active")

  // FEATURES
  supportsSlab         Boolean @default(false) @map("supports_slab")
  supportPaymentMethod Boolean @default(false) @map("support_payment_method")

  // PAYMENT GATEWAY
  paymentMethod String? @map("payment_method")
  network       String?

  // BBPS / RECHARGE
  category     String?
  operator     String?
  operatorCode String? @map("operator_code")

  // DMT / PAYOUT
  bankCode        String? @map("bank_code")
  transactionType String? @map("transaction_type")

  // SLAB
  minAmount Float? @map("min_amount")
  maxAmount Float? @map("max_amount")

  // PRICING
  mode             PricingMode      @default(NONE)
  pricingValueType PricingValueType @default(NONE) @map("pricing_value_type")
  providerCost     Float?           @map("provider_cost")

  // TAX

  applyTDS   Boolean @default(false) @map("apply_tds")
  tdsPercent Float?  @map("tds_percent")
  applyGST   Boolean @default(false) @map("apply_gst")
  gstPercent Float?  @map("gst_percent")

  // EXTRA
  handlePath String? @map("handle_path")
  config     Json?

  // TIMESTAMPS
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // RELATIONS
  service            Service             @relation(fields: [serviceId], references: [id])
  provider           Provider            @relation(fields: [providerId], references: [id])
  transactions       Transaction[]
  ledgerEntries      LedgerEntry[]
  commissionSettings CommissionSetting[]
  commissionEarnings CommissionEarning[]
  bbpsFetchBills     BbpsFetchBill[]

  // INDEXES
  @@index([serviceId])
  @@index([providerId])
  @@index([operatorCode])
  @@index([paymentMethod, network])
  @@index([bankCode])
  @@index([transactionType])
  @@index([minAmount, maxAmount])
  @@map("service_providers")
}

model Permission {
  id         String          @id @default(uuid())
  scope      PermissionScope
  userId     String?         @map("user_id")
  packageId  String?         @map("package_id")
  serviceId  String          @map("service_id")
  canView    Boolean         @default(false) @map("can_view")
  canProcess Boolean         @default(false) @map("can_process")
  isActive   Boolean         @default(true) @map("is_active")
  remarks    String?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @updatedAt @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id])
  package Package? @relation(fields: [packageId], references: [id])
  service Service  @relation(fields: [serviceId], references: [id])

  @@unique([userId, serviceId])
  @@unique([packageId, serviceId])
  @@index([userId])
  @@index([packageId])
  @@index([serviceId])
  @@index([scope])
  @@map("permissions")
}

model ApiKeyProviderMapping {
  id         String   @id @default(uuid())
  apiKeyId   String   @map("api_key_id")
  serviceId  String   @map("service_id")
  providerId String   @map("provider_id")
  priority   Int      @default(1)
  isActive   Boolean  @default(true) @map("is_active")
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([apiKeyId, serviceId, providerId])
  @@index([apiKeyId])
  @@index([providerId])
  @@index([serviceId])
  @@map("api_key_provider_mappings")
}

model SystemSetting {
  id            String    @id @default(uuid())
  userId        String?   @map("user_id")
  companyName   String    @map("company_name")
  companyLogo   String    @map("company_logo")
  favIcon       String    @map("fav_icon")
  phoneNumber   String    @map("phone_number")
  whtsappNumber String    @map("whtsapp_number")
  companyEmail  String    @map("company_email")
  facebookUrl   String    @map("facebook_url")
  instagramUrl  String    @map("instagram_url")
  twitterUrl    String    @map("twitter_url")
  linkedinUrl   String    @map("linkedin_url")
  websiteUrl    String    @map("website_url")
  settings      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  user          User?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "settings_user_id_fkey")
  @@map("settings")
}

model Transaction {
  id String @id @default(uuid())

  txnId          String @unique
  idempotencyKey String @unique

  serviceCode  String?
  providerCode String?

  amount    Float
  netAmount Float

  status String @default("PENDING")

  userId   String
  walletId String

  serviceProviderId String?

  pricing Json?

  providerReference String?

  requestInit          Json?
  providerResponseInit Json?
  providerResponse     Json?

  retryCount Int @default(0)

  initiatedAt   DateTime  @default(now())
  processedAt   DateTime?
  completedAt   DateTime?
  lastCheckedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  wallet          Wallet           @relation(fields: [walletId], references: [id])
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  ledgerEntries      LedgerEntry[]
  commissionEarnings CommissionEarning[]

  @@index([userId, status])
  @@index([status, initiatedAt])
  @@map("transactions")
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String?         @map("transaction_id")
  walletId      String          @map("wallet_id")
  entryType     LedgerEntryType @map("entry_type")
  referenceType String          @map("reference_type")

  amount         Float
  runningBalance Float        @map("running_balance")
  narration      String       @db.Text
  metadata       Json?
  idempotencyKey String?      @map("idempotency_key")
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  transaction    Transaction? @relation(fields: [transactionId], references: [id])
  wallet         Wallet       @relation(fields: [walletId], references: [id])

  serviceProviderId String?
  createdByUser     User             @relation(fields: [createdBy], references: [id])
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  @@unique([idempotencyKey])
  @@index([transactionId])
  @@index([walletId, createdAt])
  @@index([idempotencyKey])
  @@map("ledger_entries")
}

model BbpsCategory {
  id String @id @default(uuid())

  name String
  code String? @unique

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  billers BbpsBiller[]

  @@index([name])
  @@map("bbps_categories")
}

model BbpsBiller {
  id String @id @default(uuid())

  providerId String @map("provider_id")
  categoryId String @map("category_id")

  billerId   String @map("biller_id")
  billerName String @map("biller_name")

  aliasName String? @map("alias_name")

  // DETAILS API DATA
  fetchRequirement       String? @map("fetch_requirement")
  paymentAmountExactness String? @map("payment_amount_exactness")
  supportBillValidation  String? @map("support_bill_validation")

  billerMode     String? @map("biller_mode")
  billerCoverage String? @map("biller_coverage")
  ownerShip      String? @map("owner_ship")

  supportsAdhoc  Boolean? @map("supports_adhoc")
  isParentBiller Boolean? @map("is_parent_biller")

  status String?

  lastUpdated String? @map("last_updated")

  // FULL RAW RESPONSE
  metadata Json?

  detailsFetchedAt DateTime? @map("details_fetched_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id])

  category BbpsCategory @relation(fields: [categoryId], references: [id])

  bbpsCustomerParams BbpsCustomerParam[]

  bbpsFetchBills BbpsFetchBill[]

  @@unique([providerId, billerId])
  @@index([providerId])
  @@index([categoryId])
  @@index([billerId])
  @@index([billerName])
  @@map("bbps_billers")
}

model BbpsCustomerParam {
  id String @id @default(uuid())

  billerId String @map("biller_id")

  paramName String @map("param_name")

  displayName String? @map("display_name")

  dataType String @default("STRING")

  minLength Int? @map("min_length")
  maxLength Int? @map("max_length")

  isOptional Boolean @default(false) @map("is_optional")

  visibility Boolean? @default(true)

  isUnique Boolean? @default(false) @map("is_unique")

  regex String?

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  biller BbpsBiller @relation(fields: [billerId], references: [id])

  @@index([billerId])
  @@map("bbps_customer_params")
}

model BbpsFetchBill {
  id String @id @default(uuid())

  // OWNER
  userId            String @map("user_id")
  serviceProviderId String @map("service_provider_id")
  billerId          String @map("biller_id")

  // REFERENCES
  clientReferenceId String  @map("client_reference_id")
  reference         String  @unique
  fetchId           String  @unique @map("fetch_id")
  providerReference String? @map("provider_reference")

  // CUSTOMER INPUT
  customerParams    Json?   @map("customer_params")
  customerParamsKey String? @map("customer_params_key")

  // BILL DATA
  amount       Float?
  customerName String?   @map("customer_name")
  dueDate      DateTime? @map("due_date")
  expiresAt    DateTime? @map("expires_at")

  // PROVIDER STATUS
  status                  String  @default("PENDING")
  providerResponseCode    String? @map("provider_response_code")
  providerResponseMessage String? @map("provider_response_message")

  // DEBUG / AUDIT
  rawResponse Json? @map("raw_response")

  // TIMESTAMPS
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // RELATIONS
  user            User            @relation(fields: [userId], references: [id])
  biller          BbpsBiller      @relation(fields: [billerId], references: [id])
  serviceProvider ServiceProvider @relation(fields: [serviceProviderId], references: [id])

  // INDEXES
  @@index([userId])
  @@index([billerId])
  @@index([serviceProviderId])
  @@index([clientReferenceId])
  @@index([fetchId])
  @@index([status])
  @@map("bbps_fetch_bills")
}

